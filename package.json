{
  "name": "better-feed",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clean": "find . -name '._*' -type f -delete",
    "build": "npm run clean && tsc",
    "build:assets": "npm run clean && vite build",
    "build:worker": "npm run build",
    "sitemap": "node scripts/generate-sitemap.js",
    "build:all": "npm run sitemap && npm run build:assets && npm run build:worker",
    "build:dev": "cp src/components/auth/clerk.dev.tsx src/components/auth/clerk.tsx && npm run build:all",
    "build:prod": "cp src/components/auth/clerk.prod.tsx src/components/auth/clerk.tsx && npm run build:all",
    "vite": "npx vite",
    "dev": "npm run build:dev && npx wrangler dev --config wrangler.toml --remote --port 8788",
    "dev:local": "npm run build:dev && npx wrangler dev --config wrangler.toml --local --port 8788",
    "lint": "eslint .",
    "deploy": "npm run build:prod && wrangler deploy --config wrangler.toml",
    "migrate:d1": "wrangler d1 migrations apply progressive-ai-academy-db --local",
    "migrate:d1:remote": "wrangler d1 migrations apply progressive-ai-academy-db --remote"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.3",
    "@clerk/react": "^6.4.7",
    "@cloudflare/kv-asset-handler": "^0.5.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@hono/clerk-auth": "^3.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^11.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.16",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.11",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "react-syntax-highlighter": "^16.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260501.1",
    "@eslint/js": "^9.39.4",
    "@shadcn/ui": "^0.0.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "wrangler": "^4.87.0"
  }
}
